      },
      {
        "tab": "Seeker",
        "icon": "mobile",
        "groups": [
          {
            "group": "Release Notes",
            "pages": [
              "seeker/release-notes/index",
              "seeker/release-notes/mr4",
              "seeker/release-notes/mr5",
              "seeker/release-notes/mr6",
              "seeker/release-notes/mr7"
            ]
          }
        ]
      }
    ]
