{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Solana Mobile Docs",
  "colors": {
    "primary": "#000000",
    "light": "#EF5C6F",
    "dark": "#EF5C6F"
  },
  "background": {
    "decoration": "gradient"
  },
  "appearance": {
    "default": "dark"
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "fonts": {
    "body": {
      "family": "__ppMori_c9a5a4",
      "source": "https://mintlify-assets.b-cdn.net/EHeAzD6gM8HDt9NQftiBgWSV3A.woff2",
      "format": "woff2"
    },
    "heading": {
      "family": "__ppMori_c9a5a4",
      "source": "https://mintlify-assets.b-cdn.net/EHeAzD6gM8HDt9NQftiBgWSV3A.woff2",
      "format": "woff2"
    }
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "icon": "house",
        "groups": [
          {
            "group": " ",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Get Started",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "get-started/overview",
              "get-started/development-setup",
              "get-started/react-native/create-solana-mobile-app"
            ]
          },
          {
            "group": "Mobile Wallet Adapter SDK",
            "pages": [
              "get-started/mobile-wallet-adapter",
