                "group": "React Native",
                "pages": [
                  "get-started/react-native/installation",
                  "get-started/react-native/setup",
                  "get-started/react-native/quickstart",
                  {
                    "group": "Advanced",
                    "pages": [
                      "get-started/react-native/invoke-mwa-sessions-directly",
                      "get-started/react-native/mobile-wallet-adapter"
                    ]
                  }
                ]
              },
              {
                "group": "Web",
                "pages": [
                  "get-started/web/installation",
                  "get-started/web/apps",
                  "get-started/web/ux-guidelines"
                ]
