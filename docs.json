            "group": "Solana Development",
            "pages": [
              "recipes/solana-development/anchor-integration",
              "recipes/solana-development/using-anchor-programs"
            ]
          }
        ]
      },
      {
        "tab": "Saga",
        "hidden": true,
        "groups": [
          {
            "group": "Release Notes",
            "pages": [
              "saga/release-notes/index",
              "saga/release-notes/mr1",
              "saga/release-notes/mr2",
              "saga/release-notes/mr3",
              "saga/release-notes/mr4",
              "saga/release-notes/mr5",
              "saga/release-notes/2023-12-update"
